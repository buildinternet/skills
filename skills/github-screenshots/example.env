# example.env — configuration the upload script reads (DOCUMENTATION ONLY)
#
# Copy this to `.env` IN THIS SKILL FOLDER and fill in the values to make the
# skill self-contained. scripts/upload.sh resolves config + credentials in order:
#   1. the environment (whatever's already exported wins)
#   2. a .env in this skill folder   ← copy this file to .env; it is gitignored
# For auth you can instead `wrangler login` to the account that owns the bucket.
#
# Do NOT commit a real `.env` — .gitignore here excludes it (keeps example.env).

# --- Bucket (required) ------------------------------------------------------
# The R2 bucket to upload into, and its public base URL (a custom domain bound to
# the bucket). Set both so the printed URL matches where the object lands.
R2_SCREENSHOTS_BUCKET=
R2_SCREENSHOTS_PUBLIC_BASE=

# --- Credentials ------------------------------------------------------------
# A Cloudflare API token with R2 read/write, plus the account ID. Optional if you
# authenticate with `wrangler login` instead.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
